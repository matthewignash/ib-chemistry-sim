{
  "meta": {
    "source": "IB Chemistry 2025 syllabus — general solubility rules for ionic compounds in water at 25°C",
    "created": "2026-04-03",
    "updated": "2026-04-04",
    "notes": "Standard solubility rules as taught in IB Chemistry. These are generalizations with exceptions. Soluble = >1 g/100 mL, slightly soluble = 0.1–1 g/100 mL, insoluble = <0.1 g/100 mL.",
    "fieldMapping": "Flat arrays (flame_ions, precip_cations, precip_anions, precip_matrix, unknowns) match SimEngine_QualitativeAnalysis.html inline data exactly"
  },
  "rules": [
    {
      "rule": 1,
      "description": "All Group 1 (alkali metal) compounds are soluble",
      "ions": ["Li⁺", "Na⁺", "K⁺", "Rb⁺", "Cs⁺"],
      "soluble": true,
      "exceptions": []
    },
    {
      "rule": 2,
      "description": "All ammonium (NH₄⁺) compounds are soluble",
      "ions": ["NH₄⁺"],
      "soluble": true,
      "exceptions": []
    },
    {
      "rule": 3,
      "description": "All nitrate (NO₃⁻) compounds are soluble",
      "ions": ["NO₃⁻"],
      "soluble": true,
      "exceptions": []
    },
    {
      "rule": 4,
      "description": "All chlorides, bromides, and iodides are soluble",
      "ions": ["Cl⁻", "Br⁻", "I⁻"],
      "soluble": true,
      "exceptions": ["AgCl", "PbCl₂", "AgBr", "PbBr₂", "AgI", "PbI₂"]
    },
    {
      "rule": 5,
      "description": "All sulfates are soluble",
      "ions": ["SO₄²⁻"],
      "soluble": true,
      "exceptions": ["BaSO₄", "PbSO₄", "CaSO₄", "SrSO₄"]
    },
    {
      "rule": 6,
      "description": "All hydroxides are insoluble",
      "ions": ["OH⁻"],
      "soluble": false,
      "exceptions": ["NaOH", "KOH", "Ba(OH)₂", "Ca(OH)₂ (slightly soluble)"]
    },
    {
      "rule": 7,
      "description": "All oxides are insoluble",
      "ions": ["O²⁻"],
      "soluble": false,
      "exceptions": ["Na₂O (reacts)", "K₂O (reacts)", "BaO (soluble)", "CaO (slightly soluble)"]
    },
    {
      "rule": 8,
      "description": "All carbonates are insoluble",
      "ions": ["CO₃²⁻"],
      "soluble": false,
      "exceptions": ["Na₂CO₃", "K₂CO₃", "(NH₄)₂CO₃"]
    },
    {
      "rule": 9,
      "description": "All phosphates are insoluble",
      "ions": ["PO₄³⁻"],
      "soluble": false,
      "exceptions": ["Na₃PO₄", "K₃PO₄", "(NH₄)₃PO₄"]
    },
    {
      "rule": 10,
      "description": "All sulfides are insoluble",
      "ions": ["S²⁻"],
      "soluble": false,
      "exceptions": ["Na₂S", "K₂S", "(NH₄)₂S", "CaS", "BaS"]
    }
  ],
