# ============================================
# Only SimEngine simulation files belong in this repo.
# Everything else stays local.
# ============================================

# Ignore everything by default
*

# Allow SimEngine sims and supporting files
!1-Projects/
!1-Projects/SimEngine/
!1-Projects/SimEngine/**

# Allow SimEngine core engine, data, and scripts
!3-Resources/
!3-Resources/SimEngine/
!3-Resources/SimEngine/**

# Allow repo config
!.gitignore
!vercel.json

# Still exclude binaries and editor junk inside allowed dirs
*.pptx
*.docx
*.png
*.gif
*.xlsx
.DS_Store
.~lock.*
*.swp
*~
.claude/
